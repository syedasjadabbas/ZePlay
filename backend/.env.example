# ZePlay Backend — Environment Configuration
# Copy this to .env and fill in your values

PROJECT_NAME="ZePlay API"

# Database — use SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./local_zeplay.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zeplay

# JWT
JWT_SECRET_KEY=your-super-secret-key-here-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Resend Email (leave blank to use local file logging)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:5173
