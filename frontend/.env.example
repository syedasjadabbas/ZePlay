# ZePlay Frontend Environment Variables
# Copy this file to .env.local for local development
# Set these on Vercel for production

# Backend API URL — MUST end with /api
# Local development:
VITE_API_URL=http://localhost:8000/api

# Production (set on Vercel Dashboard → Settings → Environment Variables):
# VITE_API_URL=https://zeplay-backend.onrender.com/api
